---
import BaseLayout from '../layouts/BaseLayout.astro';
import BeforeAfter from '../components/BeforeAfter.jsx';

const title = 'Paintless Dent Repair | Mobile Hail Damage Repair | AllDent PDR Cincinnati';
const description = 'AllDent PDR offers expert paintless dent repair (PDR) in Cincinnati and nationwide. Mobile hail damage repair, door ding removal, and collision dent repair. Factory-finish results without repainting. Free estimates — call 1-855-425-5336.';
const faqItems = [
  { question: 'What is paintless dent repair?', answer: 'Paintless dent repair (PDR) is a technique that removes dents from vehicle panels without sanding, filling, or repainting. A technician uses specialized tools to reshape the metal from behind the panel, preserving your factory paint finish.' },
  { question: 'How much does paintless dent repair cost in Cincinnati?', answer: 'PDR cost depends on dent size, location, and accessibility. Small door dings typically range from $75-$150. Hail damage is quoted per panel. Contact AllDent PDR for a free photo-based estimate.' },
  { question: 'Where does AllDent PDR provide service?', answer: 'AllDent PDR is a mobile repair service based in Cincinnati, OH. We travel across the United States to areas affected by hail storms, providing on-site paintless dent repair wherever storm damage occurs.' },
  { question: 'How long does a typical PDR repair take?', answer: 'Most single-dent repairs are completed in 1-3 hours. Multi-panel hail damage may take a full day. We provide a timeline upfront so you can plan accordingly.' }
];
---

<BaseLayout title={title} description={description} canonical="https://alldentpdr.com" faqItems={faqItems}>
	<section class="hero">
		<div class="container hero-inner">
			<div>
				<span class="hero-pill">Paintless Dent Repair — Mobile & Nationwide</span>
				<h1>Expert paintless dent repair that comes to you — anywhere in the U.S.</h1>
				<p>
					AllDent PDR is Cincinnati's trusted mobile paintless dent repair service. We travel nationwide
					to restore vehicles damaged by hail storms — factory-quality results without repainting.
				</p>
				<div class="button-row">
					<a class="button primary" href="/contact">Get a Free Estimate</a>
					<a class="button ghost" href="/services">Our Services</a>
				</div>
			</div>
			<div class="hero-card">
				<h3>Why drivers choose AllDent PDR</h3>
				<ul>
					<li>Certified paintless dent repair technicians</li>
					<li>Nationwide storm response — we come to you</li>
					<li>Preserve your factory paint &amp; vehicle value</li>
					<li>Insurance-approved repairs with direct billing</li>
					<li>Same-day estimates from photos</li>
				</ul>
				<p class="tag">Based in Cincinnati — Serving the entire U.S.</p>
				<p>Trusted by drivers, dealerships, and insurance partners nationwide.</p>
			</div>
		</div>
	</section>

	<div class="trust-strip">
		<div class="trust-item"><strong>1,000+</strong><span>Vehicles Repaired</span></div>
		<div class="trust-item"><strong>50+</strong><span>Cities Served</span></div>
		<div class="trust-item"><strong>100%</strong><span>Paint Preserved</span></div>
		<div class="trust-item"><strong>Same Day</strong><span>Photo Estimates</span></div>
	</div>

	<section class="section alt">
		<div class="container">
			<span class="section-label">Our Services</span>
			<h2>Paintless dent repair services</h2>
			<p>Professional PDR solutions for every type of dent — from minor door dings to full hail storm recovery.</p>
			<div class="grid-3">
				<article class="card">
					<span class="tag">Door Dings</span>
					<h3>Parking lot dent repair</h3>
					<p>Quick paintless dent repair for small dings and creases — no fillers, no repainting, no hassle.</p>
				</article>
				<article class="card">
					<span class="tag">Hail Damage</span>
					<h3>Hail storm recovery</h3>
					<p>Systematic panel-by-panel hail dent repair that preserves your OEM factory finish. We deploy to storm-affected areas nationwide.</p>
				</article>
				<article class="card">
					<span class="tag">Minor Collision</span>
					<h3>Soft impact dent removal</h3>
					<p>Paintless repair for dents from low-speed collisions where the paint surface remains intact.</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<span class="section-label">How It Works</span>
			<h2>The paintless dent repair process</h2>
			<p>From estimate to finished repair — here's what to expect when you choose AllDent PDR.</p>
			<div class="process-grid">
				<div class="process-step card">
					<h3>Send Photos</h3>
					<p>Text or email photos of your damage for a free same-day estimate.</p>
				</div>
				<div class="process-step card">
					<h3>Get Your Quote</h3>
					<p>Receive transparent pricing with no hidden fees or surprises.</p>
				</div>
				<div class="process-step card">
					<h3>We Come to You</h3>
					<p>Our mobile PDR technicians arrive at your location — home, work, or dealership.</p>
				</div>
				<div class="process-step card">
					<h3>Flawless Finish</h3>
					<p>Drive away with factory-quality results. Your paint stays original, your value stays intact.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section alt">
		<div class="container">
			<span class="section-label">Our Work</span>
			<h2>Before &amp; after paintless dent repair results</h2>
			<p>Real repairs from real customers — see the difference professional PDR makes.</p>
			<div class="gallery-grid">
				<div class="card">
					<span class="tag">Door Ding</span>
					<BeforeAfter 
						client:load 
						before="/images/topdoorbefore.jpg" 
						after="/images/topdoorafter.jpg" 
						alt="Paintless dent repair Cincinnati - Door ding removal before and after showing restored factory finish"
					/>
				</div>
				<div class="card">
					<span class="tag">Hood Dent</span>
					<BeforeAfter 
						client:load 
						before="/images/pdrhoodbefore.png" 
						after="/images/pdrhoodafter.png" 
						alt="Hood dent paintless repair Cincinnati - Before and after PDR technique without repainting"
					/>
				</div>
				<div class="card">
					<span class="tag">Side Dent</span>
					<BeforeAfter 
						client:load 
						before="/images/sidedentbefore.jpg" 
						after="/images/sidedentafter.jpg" 
						alt="Side panel dent repair Cincinnati - PDR before after showing seamless paintless restoration"
					/>
				</div>
				<div class="card">
					<span class="tag">Hail Damage</span>
					<BeforeAfter 
						client:load 
						before="/images/haildamangetopbefore.jpg" 
						after="/images/haildamagetopafter.jpg" 
						alt="Hail damage repair Cincinnati - Before and after paintless dent removal from storm damage"
					/>
				</div>
				<div class="card">
					<span class="tag">Trunk Dent</span>
					<BeforeAfter 
						client:load 
						before="/images/denttrunkbefore.png" 
						after="/images/denttrunkafter.png" 
						alt="Trunk lid dent repair Cincinnati - Paintless dent repair before after comparison"
					/>
				</div>
				<div class="card">
					<span class="tag">Side Panel</span>
					<BeforeAfter 
						client:load 
						before="/images/sidepaneldentbefore.png" 
						after="/images/sidepaneldentafter.png" 
						alt="Car side panel dent repair Cincinnati - Professional PDR results preserve original paint"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<span class="section-label">Why AllDent</span>
			<h2>Why choose AllDent for paintless dent repair?</h2>
			<p>Mobile, trusted, and transparent — here's what sets us apart from traditional body shops.</p>
			<div class="grid-3">
				<article class="card">
					<h3>Transparent pricing</h3>
					<p>Photo-based estimates with clear pricing upfront — no hidden charges or upsells.</p>
				</article>
				<article class="card">
					<h3>Fast turnaround</h3>
					<p>Most paintless dent repairs are completed in hours, not days. Get back on the road fast.</p>
				</article>
				<article class="card">
					<h3>Factory finish preserved</h3>
					<p>Our PDR techniques keep your original paint intact, protecting your vehicle's resale value.</p>
				</article>
			</div>
		</div>
	</section>

	<section class="cta-banner">
		<div class="container">
			<h2>Hail damage? We'll come to you.</h2>
			<p>Tell us about the storm damage and your location — we reply with next steps the same day.</p>
			<div class="button-row" style="justify-content: center;">
				<a class="button primary" href="/contact">Start Your Free Estimate</a>
				<a class="button ghost" href="tel:18554255336">Call 1-855-425-5336</a>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<h2>Paintless dent repair FAQ</h2>
			<div class="faq-list">
				<details class="faq-item">
					<summary>What is paintless dent repair?</summary>
					<p>Paintless dent repair (PDR) is a technique that removes dents from vehicle panels without sanding, filling, or repainting. A technician uses specialized tools to reshape the metal from behind the panel, preserving your factory paint finish.</p>
				</details>
				<details class="faq-item">
					<summary>How much does paintless dent repair cost in Cincinnati?</summary>
					<p>PDR cost depends on dent size, location, and accessibility. Small door dings typically range from $75–$150. Hail damage is quoted per panel. Contact AllDent PDR for a free photo-based estimate.</p>
				</details>
				<details class="faq-item">
					<summary>Where does AllDent PDR provide service?</summary>
					<p>AllDent PDR is a mobile repair service based in Cincinnati, OH. We travel across the United States to areas affected by hail storms, providing on-site paintless dent repair wherever storm damage occurs.</p>
				</details>
				<details class="faq-item">
					<summary>How long does a typical PDR repair take?</summary>
					<p>Most single-dent repairs are completed in 1–3 hours. Multi-panel hail damage may take a full day. We provide a timeline upfront so you can plan accordingly.</p>
				</details>
			</div>
		</div>
	</section>
</BaseLayout>
